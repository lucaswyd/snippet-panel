# Gofile API token for downloading files from gofile.io links
# Get your token from: https://gofile.io/myAccount
GOFILE_TOKEN=your_gofile_token_here

# GitHub token for repository operations
GITHUB_TOKEN=your_github_token

# GitHub repository configuration
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repo_name
SNIPPETS_REPO_OWNER=your_github_username
SNIPPETS_REPO_NAME=your_snippets_repo_name

# Discord configuration
DISCORD_BOT_TOKEN=your_discord_bot_token
WEBHOOK_SNIPPETS=your_webhook_url
WEBHOOK_BLANK=your_blank_channel_webhook_url
WEBHOOK_PUBLIC_SNIPPETS=your_public_snippets_webhook_url
WEBHOOK_PRIVATE_SNIPPETS=your_private_snippets_webhook_url
WEBHOOK_PUBLIC_SEPARATOR=your_public_separator_webhook_url
WEBHOOK_PRIVATE_SEPARATOR=your_private_separator_webhook_url
WEBHOOK_NEW_SNIPPETS=your_new_snippets_webhook_url
CHANNEL_A_ID=your_channel_a_id
CHANNEL_B_ID=your_channel_b_id
PUBLIC_CHANNEL_ID=your_public_channel_id
PRIVATE_CHANNEL_ID=your_private_channel_id

# Internal API secret
CALLBACK_SECRET=your_internal_secret

# Vercel configuration
VERCEL_APP_URL=your_vercel_app_url

# Optional delays (in milliseconds)
QUEUE_SNIPPET_DELAY_MS=1200
FULL_ARCHIVE_SNIPPET_DELAY_MS=2000
FULL_POST_SNIPPET_DELAY_MS=2000

# Discord timeout configuration
DISCORD_WEBHOOK_HTTP_TIMEOUT_MS=180000
DISCORD_BOT_HTTP_TIMEOUT_MS=120000
DISCORD_WEBHOOK_429_MAX_WAIT_SEC=900

# Optional: Skip workspace for local development
SNIPPETS_SKIP_WORKSPACE=0

# Optional: Use build bundle instead of workspace
SNIPPETS_USE_BUILD_BUNDLE=0
